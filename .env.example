# ============================================================
# 云服务器 Docker 部署配置模板
# 复制此文件为 .env 并修改为你的实际配置
# ============================================================

# ============================================================
# MySQL 数据库配置
# ============================================================
# Docker 部署时，Spring Boot 容器内通过 Docker 网络访问 mysql:3306
# 本地电脑可以通过 云服务器IP:13306 连接
DB_HOST=localhost
DB_PORT=3306
DB_NAME=eladmin
DB_USER=root
DB_PWD=your_password_here  # 改成你想设置的 MySQL root 密码

# ============================================================
# Redis 配置
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PWD=

# ============================================================
# Spring 配置
# ============================================================
SPRING_PROFILES_ACTIVE=prod

# ============================================================
# 端口映射说明
# ============================================================
# 云服务器对外暴露端口：
#   - 8080  -> Spring Boot 应用
#   - 13306 -> MySQL（可从本地电脑连接）
#   - 6379 -> Redis（仅绑定本地 127.0.0.1，不对外暴露）
