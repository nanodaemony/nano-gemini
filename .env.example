# ============================================================
# little-grid Backend 环境变量配置文件
# 复制此文件为 .env 并修改为你的实际配置
# ============================================================

# ============================================================
# MySQL 数据库配置 (必需)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=eladmin
DB_USER=root
DB_PWD=your_password

# ============================================================
# Redis 配置 (必需)
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PWD=

# ============================================================
# 可选配置：Spring 配置文件激活
# ============================================================
# 可选值: dev, prod, quartz
# dev: 开发环境
# prod: 生产环境
# quartz: 启用分布式定时任务
SPRING_PROFILES_ACTIVE=prod

# ============================================================
# 可选配置：服务端口号
# ============================================================
SERVER_PORT=8000
