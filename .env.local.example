# ============================================================
# 本地开发环境配置模板
# 复制此文件为 .env 并修改为你的实际配置
# ============================================================

# ============================================================
# MySQL 数据库配置 - 连接云服务器的 MySQL
# ============================================================
#
# 把下面改成你的云服务器IP：
#
DB_HOST=123.45.67.89    # 换成你的云服务器IP
DB_PORT=13306            # 云服务器映射的 MySQL 端口
DB_NAME=eladmin
DB_USER=root
DB_PWD=你的密码           # 和云服务器 .env 里的 DB_PWD 一致

# ============================================================
# Redis 配置 - 用本地 Redis
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PWD=

# ============================================================
# Spring 配置
# ============================================================
SPRING_PROFILES_ACTIVE=dev
