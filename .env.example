# ============================================================
# 云服务器部署配置模板
# 复制此文件为 .env 并修改为你的实际配置
# ============================================================

# ============================================================
# MySQL 数据库配置
# ============================================================
# Docker 部署 MySQL，端口映射 13306:3306
# Spring Boot 本地连接用 127.0.0.1:13306
# 本地电脑也可以通过 云服务器IP:13306 连接
DB_HOST=127.0.0.1
DB_PORT=13306
DB_NAME=eladmin
DB_USER=root
DB_PWD=your_password_here  # 改成你想设置的 MySQL root 密码

# ============================================================
# Redis 配置
# ============================================================
# Docker 部署 Redis，仅本地 127.0.0.1:6379 访问
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PWD=

# ============================================================
# Spring 配置
# ============================================================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ============================================================
# 阿里云 OSS 配置
# ============================================================
ALI_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALI_OSS_ACCESS_KEY_ID=你的AccessKeyId
ALI_OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
ALI_OSS_BUCKET_NAME=你的bucket名称
ALI_OSS_DOMAIN=你的OSS访问域名（如：https://your-bucket.oss-cn-hangzhou.aliyuncs.com）
ALI_OSS_TIMEFORMAT=yyyy-MM

# ============================================================
# 阿里云百炼 TTS 配置
# ============================================================
DASHSCOPE_API_KEY=你的API Key

# ============================================================
# 火山引擎 TTS 配置
# ============================================================
VOLCENGINE_API_KEY=你的火山引擎API Key
